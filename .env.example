# Supabase API keys for live database sync
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Google Authentication & NextAuth/Auth.js placeholders
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET
NEXTAUTH_URL=http://localhost:3000

# Cloudflare R2 configurations
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=

# Alternatively, you can use standard S3 names (both sets are supported natively by the app):
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Cloudflare Public R2 access domain (e.g. https://pub-xxxxxx.r2.dev or custom domain)
R2_PUBLIC_URL=REPLACE_WITH_PUBLIC_R2_DEV_URL

# Resend API key for email OTP verification
RESEND_API_KEY=
# Custom sender email if you have verified your own domain on Resend (e.g. otp@yourdomain.com)
# If blank, falls back to onboarding@resend.dev (which only sends to your own registered email)
RESEND_FROM_EMAIL=

